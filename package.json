{
  "name": "@smoose/pi-persona",
  "version": "0.1.0",
  "description": "A pi extension that adds persistent persona and emotional state to your coding agent",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsc --outDir .tmp-test --noEmit false && node --test .tmp-test/src/**/*.test.js"
  },
  "keywords": [
    "pi-package",
    "personality",
    "mood",
    "emotion"
  ],
  "author": "smoose",
  "license": "MIT",
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoosex/pi-persona.git"
  },
  "homepage": "https://github.com/smoosex/pi-persona",
  "bugs": {
    "url": "https://github.com/smoosex/pi-persona/issues"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "extensions"
  ],
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
